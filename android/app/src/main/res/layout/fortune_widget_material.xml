<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/fortune_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/fortune_widget_bg_material"
    android:paddingStart="30dp"
    android:paddingEnd="30dp"
    android:paddingTop="18dp"
    android:paddingBottom="18dp"
    android:gravity="center_vertical">

    <TextView
        android:id="@+id/fortune_quote"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text=""
        android:textColor="@color/fortune_material_text"
        android:textSize="13sp"
        android:fontFamily="serif"
        android:lineSpacingMultiplier="1.25" />

    <TextView
        android:id="@+id/fortune_attr"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:text=""
        android:textColor="@color/fortune_material_muted"
        android:textSize="11sp"
        android:fontFamily="sans-serif" />

</LinearLayout>
