<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/fortune_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/fortune_widget_bg_dark"
    android:padding="16dp">

    <!-- Header row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="✦ Lucky Lat·Lang"
            android:textColor="#6C6A64"
            android:textSize="9sp"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.08" />

        <ImageView
            android:id="@+id/fortune_refresh_btn"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@drawable/ic_fortune_refresh"
            android:padding="6dp"
            android:contentDescription="New quote" />

    </LinearLayout>

    <!-- Quote body -->
    <TextView
        android:id="@+id/fortune_quote"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="8dp"
        android:text=""
        android:textColor="#FAF9F5"
        android:textSize="14sp"
        android:fontFamily="serif"
        android:textStyle="italic"
        android:lineSpacingMultiplier="1.55"
        android:gravity="center_vertical" />

    <!-- Attribution -->
    <TextView
        android:id="@+id/fortune_attr"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text=""
        android:textColor="#6C6A64"
        android:textSize="10sp"
        android:fontFamily="sans-serif" />

</LinearLayout>
