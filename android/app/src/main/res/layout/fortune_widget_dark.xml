<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/fortune_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/fortune_widget_bg_dark"
    android:paddingStart="22dp"
    android:paddingEnd="22dp"
    android:paddingTop="18dp"
    android:paddingBottom="18dp"
    android:gravity="center_vertical">

    <TextView
        android:id="@+id/fortune_quote"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text=""
        android:textColor="#FAF9F5"
        android:textSize="17sp"
        android:fontFamily="serif"
        android:lineSpacingMultiplier="1.55" />

    <TextView
        android:id="@+id/fortune_attr"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:text=""
        android:textColor="#6C6A64"
        android:textSize="11sp"
        android:fontFamily="sans-serif" />

</LinearLayout>
